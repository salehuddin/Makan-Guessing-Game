# GuessEat Production Environment
# Copy this file to .env (project root) and packages/api/.env before deploying.
#
# For docker-compose / Coolify:
#   Root .env provides VITE_API_URL + DB_* for the postgres service.
#   packages/api/.env is the API's working env (mounted into containers).
#
# For production, set these values via Coolify UI or in packages/api/.env.

# ── General ──────────────────────────────────────────────────────────
APP_ENV=production
APP_DEBUG=false
APP_KEY=
APP_URL=https://api.guesseat.my       # Change to your actual API domain

# ── Frontend ─────────────────────────────────────────────────────────
VITE_API_URL=                          # Leave empty for same-origin; set to https://api.guesseat.my otherwise
FRONTEND_URL=https://guesseat.my        # CORS origin for the web SPA

# ── Database ─────────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=postgres                        # Service name in docker-compose
DB_PORT=5432
DB_DATABASE=guesseat
DB_USERNAME=guesseat
DB_PASSWORD=secret                       # CHANGE THIS

# ── Redis ────────────────────────────────────────────────────────────
REDIS_HOST=redis                        # Service name in docker-compose
REDIS_PORT=6379
REDIS_PASSWORD=                          # Optional
REDIS_DB=0
REDIS_CACHE_DB=1

# ── Cache / Queue / Session ──────────────────────────────────────────
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# ── Broadcaster (Reverb) ─────────────────────────────────────────────
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=0.0.0.0
REVERB_PORT=8080
REVERB_SCHEME=http
VITE_REVERB_APP_KEY=${REVERB_APP_KEY}

# ── OTP / Auth ────────────────────────────────────────────────────────
OTP_DRIVER=dev                           # Change to "twilio" in production
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# ── Storage (Cloudflare R2) ──────────────────────────────────────────
FILESYSTEM_DISK=r2
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=guesseat
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_URL=                                  # R2 public URL (if bucket is public)

# ── Social Auth ──────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
FACEBOOK_CLIENT_ID=
APPLE_CLIENT_ID=
TIKTOK_CLIENT_KEY=

# ── Google APIs ─────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=          # Path to GCP service account JSON

# ── Mail ─────────────────────────────────────────────────────────────
MAIL_MAILER=log                          # Change to smtp/ses/postmark/resend
MAIL_FROM_ADDRESS=noreply@guesseat.my
MAIL_FROM_NAME=GuessEat

# ── Logging ──────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_LEVEL=warning

# ── Package root DB (for docker-compose postgres service) ─────────────
# These are consumed by docker-compose.yml to set up the postgres container.
# Keep them in sync with DB_* above.
DB_DATABASE=guesseat
DB_USERNAME=guesseat
DB_PASSWORD=secret
