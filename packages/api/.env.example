APP_NAME=GuessEat
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# Public URL of the web SPA (CORS, Sanctum stateful domains). Set in production.
FRONTEND_URL=http://localhost:5173

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=guesseat
DB_USERNAME=guesseat
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

OTP_DRIVER=dev
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=guesseat
R2_URL=
R2_ENDPOINT=

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=
REVERB_PORT=8080
REVERB_SCHEME=http
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"

SENTRY_LARAVEL_DSN=

# ─────────────────────────────────────────────────────────────────────────
# Production overrides (uncomment and set when deploying)
# ─────────────────────────────────────────────────────────────────────────
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://api.guesseat.my
# FRONTEND_URL=https://guesseat.my
# SESSION_DRIVER=redis
# BROADCAST_CONNECTION=reverb
# FILESYSTEM_DISK=r2
# QUEUE_CONNECTION=redis
# CACHE_STORE=redis
# LOG_STACK=stderr
# LOG_LEVEL=warning
# OTP_DRIVER=twilio