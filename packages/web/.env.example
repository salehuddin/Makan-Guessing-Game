# Web app environment variables (copy to .env for local dev)
# When empty, the SPA calls /api on its own origin (dev proxy or same-host API).

# Absolute URL of the Laravel API when the SPA is hosted on a different origin
# (e.g. Cloudflare Pages). Example:
# VITE_API_URL=https://api.guesseat.my
VITE_API_URL=

# Reverb WebSocket settings (Phase 3)
VITE_REVERB_APP_KEY=
VITE_REVERB_HOST=
VITE_REVERB_PORT=
VITE_REVERB_SCHEME=