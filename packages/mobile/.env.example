# Mobile app environment variables (Expo / EAS Build)
# Set these via EAS environment variables (`eas env:push`) or in
# `eas.json` `env` sections. Local dev uses safe fallbacks when unset.

# Absolute URL of the Laravel API used by the player app.
# Examples:
#   Local iOS sim:  http://127.0.0.1:8000/api
#   Local Android:  http://10.0.2.2:8000/api
#   Production:     https://api.guesseat.my/api
EXPO_PUBLIC_API_URL=

# Reverb WebSocket settings (Phase 3)
EXPO_PUBLIC_REVERB_APP_KEY=
EXPO_PUBLIC_REVERB_HOST=
EXPO_PUBLIC_REVERB_PORT=
EXPO_PUBLIC_REVERB_SCHEME=